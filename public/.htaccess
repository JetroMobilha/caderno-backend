<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -TrackProcessedConnections
    </IfModule>

    RewriteEngine On
    
    # 🚀 INJETA ESTA LINHA: Avisa o Apache que a base desta aplicação é a subpasta
    RewriteBase /api-caderno/

    # Redireciona barras finais sem quebrar a subpasta
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /api-caderno/$1 [L,R=301]

    # Envia o tráfego para o index.php do Caderno
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>